{
  "name": "basketball-data-chatbot-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:types": "openapi-typescript ./openapi.json -o src/generated/api.d.ts",
    "gen:sse-schema": "cd .. && uv run python scripts/export_sse_schema.py"
  },
  "dependencies": {
    "@tanstack/react-table": "^8",
    "@tanstack/react-virtual": "^3",
    "highlight.js": "^11",
    "openapi-fetch": "^0.10",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4",
    "@eslint/js": "^9",
    "@playwright/test": "^1.51",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/node": "^22",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "globals": "^15",
    "jsdom": "^25",
    "openapi-typescript": "^7",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1",
    "typescript": "~5.7",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^3"
  }
}
