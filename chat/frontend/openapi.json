{
  "components": {
    "schemas": {
      "ConfigResponse": {
        "description": "Public (non-secret) runtime config surfaced at `GET /api/config`.",
        "properties": {
          "latency_tiers": {
            "$ref": "#/components/schemas/LatencyTiers"
          },
          "openrouter_model": {
            "title": "Openrouter Model",
            "type": "string"
          }
        },
        "required": [
          "openrouter_model",
          "latency_tiers"
        ],
        "title": "ConfigResponse",
        "type": "object"
      },
      "CreateSessionRequest": {
        "description": "Body for `POST /api/sessions` (PLAN \u00a77.9).\n\n``title`` is optional; the store falls back to ``\"New chat\"`` when\nthe field is omitted, empty, or whitespace-only.",
        "properties": {
          "title": {
            "anyOf": [
              {
                "maxLength": 200,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          }
        },
        "title": "CreateSessionRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Response shape for `GET /api/health`.",
        "properties": {
          "db": {
            "title": "Db",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "db"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "HistoryPage": {
        "description": "One paginated window over a session's visible messages.",
        "properties": {
          "limit": {
            "title": "Limit",
            "type": "integer"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/SessionMessage"
            },
            "title": "Messages",
            "type": "array"
          },
          "offset": {
            "title": "Offset",
            "type": "integer"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "session_id",
          "messages",
          "total",
          "limit",
          "offset"
        ],
        "title": "HistoryPage",
        "type": "object"
      },
      "LatencyTiers": {
        "description": "Latency budget per template complexity tier (PLAN \u00a713).",
        "properties": {
          "heavy_seconds": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              }
            ],
            "title": "Heavy Seconds",
            "type": "array"
          },
          "heavy_timeout_seconds": {
            "title": "Heavy Timeout Seconds",
            "type": "integer"
          },
          "medium_seconds": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              }
            ],
            "title": "Medium Seconds",
            "type": "array"
          },
          "simple_seconds": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              }
            ],
            "title": "Simple Seconds",
            "type": "array"
          }
        },
        "required": [
          "simple_seconds",
          "medium_seconds",
          "heavy_seconds",
          "heavy_timeout_seconds"
        ],
        "title": "LatencyTiers",
        "type": "object"
      },
      "SessionMessage": {
        "description": "One visible message in a session.\n\nRole is a free-form string at the storage layer; the route layer\nenforces the ``\"user\" | \"assistant\"`` subset at write time (Phase 4\nSSE pipeline). Keeping the model open at the store keeps this module\nindependent of that pipeline.",
        "properties": {
          "content": {
            "title": "Content",
            "type": "string"
          },
          "role": {
            "title": "Role",
            "type": "string"
          },
          "ts": {
            "format": "date-time",
            "title": "Ts",
            "type": "string"
          }
        },
        "required": [
          "role",
          "content",
          "ts"
        ],
        "title": "SessionMessage",
        "type": "object"
      },
      "SessionMeta": {
        "description": "Metadata for a single visible chat session.\n\nSurfaces the minimum the UI needs to render a session list without\nscanning the per-session JSONL messages file.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "message_count": {
            "default": 0,
            "title": "Message Count",
            "type": "integer"
          },
          "status": {
            "default": "active",
            "title": "Status",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "created_at"
        ],
        "title": "SessionMeta",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Basketball Data Chatbot API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Tiny index so `curl http://localhost:8787/` returns something useful.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Root",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/config": {
      "get": {
        "description": "Return non-secret runtime config to the frontend.",
        "operationId": "config_api_config_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Config",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/debug/artifacts/{artifact_id}": {
      "get": {
        "description": "Fetch a query/model debug artifact by id.\n\nPhase 2 stub: no real artifact index exists yet \u2014 Phase 4 will\nmaterialise artifacts under ``chat/logs/{queries,model}`` and resolve\n``artifact_id`` (a query id or a model-log filename) to the matching\nJSONL/SQL file on disk. For now every id 404s so clients can rely on\nthe contract; the response body documents the gap.",
        "operationId": "get_debug_artifact_api_debug_artifacts__artifact_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "artifact_id",
            "required": true,
            "schema": {
              "title": "Artifact Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Get Debug Artifact Api Debug Artifacts  Artifact Id  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Debug Artifact",
        "tags": [
          "sessions"
        ]
      }
    },
    "/api/health": {
      "get": {
        "description": "Return app + warehouse status.\n\nAlways returns HTTP 200 so monitoring can detect the process even when\nthe warehouse is degraded. The `db` field reports the warehouse status.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/sessions": {
      "get": {
        "description": "Return every session's meta (no messages).\n\nNot explicitly in PLAN \u00a77.9 but useful for the UI's session-list view;\nkept here so the OpenAPI snapshot exposes the shape to the frontend\ncodegen.",
        "operationId": "list_sessions_api_sessions_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SessionMeta"
                  },
                  "title": "Response List Sessions Api Sessions Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Sessions",
        "tags": [
          "sessions"
        ]
      },
      "post": {
        "description": "Create a new session with the given (or default) title.\n\nBody is optional so a bare ``POST /api/sessions`` (no payload) yields\nthe same default-title session. Returns ``201 Created`` with the\nfreshly minted `SessionMeta`.",
        "operationId": "create_session_api_sessions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/CreateSessionRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionMeta"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Session",
        "tags": [
          "sessions"
        ]
      }
    },
    "/api/sessions/{session_id}": {
      "delete": {
        "description": "Clear the visible history (PLAN \u00a77.9 manual-clear).\n\nThe session's meta (title, id, created_at) is preserved so the UI can\nkeep showing the empty session in its list. ``404`` if the meta is\nmissing \u2014 the caller asked to clear something that never existed.",
        "operationId": "delete_session_api_sessions__session_id__delete",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "title": "Session Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Delete Session",
        "tags": [
          "sessions"
        ]
      },
      "get": {
        "description": "Return meta for one session.",
        "operationId": "get_session_api_sessions__session_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "title": "Session Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionMeta"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Session",
        "tags": [
          "sessions"
        ]
      }
    },
    "/api/sessions/{session_id}/history": {
      "get": {
        "description": "Return one paginated window of visible messages.\n\n``limit`` is clamped to ``[1, 200]``; non-positive or oversized\nvalues fall back to the default. ``offset`` must be non-negative\n(FastAPI rejects negatives with 422). Raises ``404`` for unknown\nsessions so the UI can distinguish \"empty history\" from \"session\nwas deleted\".",
        "operationId": "get_history_api_sessions__session_id__history_get",
        "parameters": [
          {
            "in": "path",
            "name": "session_id",
            "required": true,
            "schema": {
              "title": "Session Id",
              "type": "string"
            }
          },
          {
            "description": "Page size. Out-of-range (non-positive, >200) is clamped to the default of 50 by the server.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "description": "Page size. Out-of-range (non-positive, >200) is clamped to the default of 50 by the server.",
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "description": "Number of oldest messages to skip.",
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "description": "Number of oldest messages to skip.",
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoryPage"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get History",
        "tags": [
          "sessions"
        ]
      }
    }
  }
}
