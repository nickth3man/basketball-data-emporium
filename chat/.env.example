# Required: OpenRouter API key for the chat agent. Never commit a real value.
OPENROUTER_API_KEY=sk-or-...

# Required: chat model id.
# Default (from config.py): "anthropic/claude-sonnet-4.6"
# Previous default "mistralai/mistral-small-2603" is deprecated.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: pin a specific OpenRouter provider (e.g. "deepinfra").
# When empty/unset, OpenRouter auto-routes across all providers.
# See: https://openrouter.ai/docs/guides/routing/provider-selection
OPENROUTER_PROVIDER=

# Optional: max output tokens for OpenRouter calls.
# Default 16384. Higher values prevent tool-call JSON truncation when the
# system prompt is large.
# OPENROUTER_MAX_TOKENS=16384

# Required: path to the NBA warehouse. Relative paths resolve from chat/.
DUCKDB_PATH=../data/nba.duckdb

# Required: log root for JSONL logs (sessions, queries, model).
CHAT_LOG_DIR=./logs

# Required: visible session storage root (chat/data/sessions/<session_id>.jsonl).
CHAT_DATA_DIR=./data

# Optional: comma-separated list of allowed CORS origins.
# Default: "http://localhost:5173" (Vite dev server).
# Trailing slashes and extra whitespace are stripped automatically.
# Set to "*" to allow any origin (not recommended outside development).
# WARNING: "*" is only valid as the sole origin — mixing it with specific
# origins silently falls back to the default.
# Example: CHAT_CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
# CHAT_CORS_ORIGINS=http://localhost:5173

# Optional: wall-clock budget (seconds) for governed SQL execution. Default 300.
# CHAT_QUERY_TIMEOUT=300

# Optional: DuckDB memory_limit applied at connection open. Default 8GB.
# CHAT_MEMORY_LIMIT=8GB
