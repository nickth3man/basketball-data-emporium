# Required: OpenRouter API key for the chat agent. Never commit a real value.
OPENROUTER_API_KEY=sk-or-...

# Required: chat model id. Switch before live testing.
OPENROUTER_MODEL=mistralai/mistral-small-2603

# Required: path to the NBA warehouse. Relative paths resolve from chat/.
DUCKDB_PATH=../data/nba.duckdb

# Required: log root for JSONL logs (sessions, queries, model).
CHAT_LOG_DIR=./logs

# Required: visible session storage root (chat/data/sessions/<session_id>.jsonl).
CHAT_DATA_DIR=./data

# Optional: wall-clock budget (seconds) for governed SQL execution. Default 300.
# CHAT_QUERY_TIMEOUT=300

# Optional: DuckDB memory_limit applied at connection open. Default 8GB.
# CHAT_MEMORY_LIMIT=8GB
