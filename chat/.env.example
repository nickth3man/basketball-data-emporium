# Required: OpenRouter API key for the chat agent. Never commit a real value.
OPENROUTER_API_KEY=sk-or-...

# Required: chat model id. Switch before live testing (see PLAN §17 #2).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Required: path to the NBA warehouse. Relative paths resolve from chat/.
DUCKDB_PATH=../data/nba.duckdb

# Required: log root for JSONL logs (sessions, queries, model).
CHAT_LOG_DIR=./logs
