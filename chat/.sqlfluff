[sqlfluff]
dialect = duckdb
templater = placeholder
exclude_rules = L016,L031,L034

[sqlfluff:templater:placeholder]
param_style = dollar
# Dummy values for every $param are extended per template via inline overrides.
# The placeholder templater requires a placeholder definition for each $param
# referenced in the SQL; the template loader is expected to provide per-file
# stub configs on demand. Linting in CI runs against the live `*.sql` files
# with their `*.py` sibling metadata driving the stub.

[sqlfluff:rules]
indent_unit = space
tab_space_size = 2
capitalisation.keywords = upper
capitalisation.literals = lower
